{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fealyx.github.io/tvs/schemas/mods/assets.manifest.schema.json",
  "title": "Mods Asset Manifest",
  "type": "object",
  "required": [
    "schemaVersion",
    "project",
    "assets"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "project": {
      "type": "object",
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string"
        },
        "root": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "producer": {
      "type": "object",
      "properties": {
        "tool": {
          "type": "string"
        },
        "unityVersion": {
          "type": "string"
        },
        "sourceProject": {
          "type": "string"
        },
        "builtAtUtc": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": true
    },
    "assets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "type",
          "path",
          "required"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "bundle",
              "loose",
              "assembly"
            ]
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "required": {
            "type": "boolean"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-fA-F0-9]{64}$"
          },
          "releasePath": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          },
          "notes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
