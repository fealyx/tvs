{
  "name": "@tvs/mods",
  "version": "0.0.0",
  "private": true,
  "description": "BepInEx mod development workspace for The Villain Simulator",
  "scripts": {
    "build": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/build.ps1",
    "rebuild": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/build.ps1 -Rebuild",
    "clean": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/build.ps1 -Clean",
    "validate:assets": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/validate-mod-assets.ps1 -All",
    "validate:assets:ci": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/validate-mod-assets.ps1 -All -CiSummary",
    "release:prepare": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/prepare-mod-release.ps1 -Configuration Release -OutputRoot ./release-artifacts/mods",
    "mod:deploy": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/mod-manager.ps1 -Action deploy-all",
    "mod:install:bepinex": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/mod-manager.ps1 -Action install-bepinex",
    "mod:install:dev": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/mod-manager.ps1 -Action install-dev-mods"
  }
}
