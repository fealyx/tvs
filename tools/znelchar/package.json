{
  "name": "@tvs/znelchar-tools",
  "version": "0.1.0",
  "private": true,
  "description": "Tools and schemas for working with .znelchar files",
  "scripts": {
    "build": "npm run build:dist",
    "rebuild": "npm run build:dist",
    "build:dist:release": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./build/package.ps1 -Clean -DownloadPortableRuntime",
    "inspect": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/inspect.ps1",
    "extract": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/extract.ps1",
    "pack": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/pack.ps1",
    "dump-yaml": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/dump-yaml.ps1",
    "verify": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/verify-znelchar.ps1",
    "verify:ci": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/verify-znelchar.ps1 -CiSummary",
    "verify:report": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/verify-znelchar.ps1 -DiffReportPath ./out/verify-diff.json",
    "verify:roundtrip": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/roundtrip-verify.ps1",
    "verify:roundtrip:ci": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/roundtrip-verify.ps1 -CiSummary",
    "update:check": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/update-znelchar.ps1 -Operation check",
    "update:install": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/update-znelchar.ps1 -Operation install",
    "update:verify": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/update-znelchar.ps1 -Operation verify",
    "update:selftest": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/update-selftest.ps1",
    "update:selftest:matrix": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/update-selftest.ps1 -Variants core,module,portable",
    "build:dist": "npm run build:dist:module && npm run build:dist:core && npm run build:dist:portable",
    "build:dist:core": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./build/package.ps1 -CreateCore -CreateModule:'$false' -CreatePortable:'$false'",
    "build:dist:portable": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./build/package.ps1 -CreatePortable -CreateModule:'$false' -CreateCore:'$false' -DownloadPortableRuntime",
    "build:dist:module": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./build/package.ps1 -CreateModule -CreateCore:'$false' -CreatePortable:'$false'"
  }
}
