{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fealyx.github.io/tvs/schemas/znelchar/characterData.schema.json",
  "title": "znelchar characterData",
  "type": "object",
  "properties": {
    "version": {
      "type": "string"
    },
    "isSynth": {
      "type": "boolean"
    },
    "blendshapes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "value": {
            "type": "number"
          }
        },
        "required": [
          "name",
          "value"
        ],
        "additionalProperties": true
      }
    },
    "accessories": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "skinData": {
      "type": "object",
      "additionalProperties": true
    },
    "customIconData": {
      "type": "string",
      "contentEncoding": "base64",
      "description": "Optional base64-encoded icon image data (PNG, JPG, GIF, WebP, or BMP). When extracted, this field is removed from character.json and written to a separate customIcon.<ext> file, then restored during packing."
    }
  },
  "additionalProperties": true
}
