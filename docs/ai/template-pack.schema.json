{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fealyx.dev/schemas/mod-dev/template-pack.schema.json",
  "title": "TVS mod-dev template pack",
  "description": "Declarative template pack definition consumed by the mod-dev engine.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "name",
    "version",
    "baseProfile",
    "templates"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+([.-][a-z0-9]+)*$"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "description": {
      "type": "string",
      "maxLength": 2000
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(-[A-Za-z0-9.-]+)?$"
    },
    "baseProfile": {
      "type": "string",
      "enum": [
        "mod-only",
        "single-repo",
        "monorepo"
      ]
    },
    "compatibleAddOns": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+([.-][a-z0-9]+)*$"
      }
    },
    "parameters": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/parameter"
      }
    },
    "directories": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/directory"
      }
    },
    "templates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/templateFile"
      }
    },
    "postActions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/postAction"
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": {
        "type": [
          "string",
          "number",
          "boolean",
          "null"
        ]
      }
    }
  },
  "$defs": {
    "condition": {
      "type": "string",
      "description": "Expression language string evaluated by the engine (v1: optional, may be ignored if not implemented)."
    },
    "parameter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key",
        "type"
      ],
      "properties": {
        "key": {
          "type": "string",
          "pattern": "^[A-Za-z][A-Za-z0-9_]*$"
        },
        "type": {
          "type": "string",
          "enum": [
            "string",
            "boolean",
            "choice"
          ]
        },
        "description": {
          "type": "string",
          "maxLength": 1000
        },
        "required": {
          "type": "boolean",
          "default": false
        },
        "default": {
          "type": [
            "string",
            "boolean"
          ]
        },
        "choices": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "pattern": {
          "type": "string"
        }
      }
    },
    "directory": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "when": {
          "$ref": "#/$defs/condition"
        }
      }
    },
    "templateFile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "target"
      ],
      "properties": {
        "source": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "type": "string",
          "enum": [
            "template",
            "copy"
          ],
          "default": "template"
        },
        "overwrite": {
          "type": "boolean",
          "default": false
        },
        "when": {
          "$ref": "#/$defs/condition"
        }
      }
    },
    "postAction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "command"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "args": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "workingDirectory": {
          "type": "string"
        },
        "when": {
          "$ref": "#/$defs/condition"
        },
        "continueOnError": {
          "type": "boolean",
          "default": false
        }
      }
    }
  }
}
